{
  "expo": {
    "name": "mobilerobot",
    "slug": "mobilerobot",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Разрешите доступ к микрофону для отправки голосовых команд роботу.",
          "speechRecognitionPermission": "Разрешите доступ к распознаванию речи для отправки голосовых команд роботу."
        }
      ]
    ],
    "android": {
      "package": "com.nordeveloper.mobilerobot"
    },
    "extra": {
      "eas": {
        "projectId": "f582cb46-6f1a-402a-b450-293f711896a6"
      }
    }
  }
}
