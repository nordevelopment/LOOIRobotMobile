{
  "expo": {
    "name": "mobilerobot",
    "slug": "mobilerobot",
    "version": "0.0.5",
    "orientation": "default",
    "userInterfaceStyle": "dark",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow access to the microphone to send voice commands to the robot.",
          "speechRecognitionPermission": "Allow access to speech recognition to send voice commands to the robot."
        }
      ]
    ],
    "android": {
      "package": "com.nordeveloper.mobilerobot"
    },
    "extra": {
      "eas": {
        "projectId": "f582cb46-6f1a-402a-b450-293f711896a6"
      }
    }
  }
}