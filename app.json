{
  "expo": {
    "name": "BIBO Robot App",
    "slug": "biborobotapp",
    "version": "0.0.6",
    "orientation": "default",
    "userInterfaceStyle": "dark",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow access to the microphone to send voice commands to the robot.",
          "speechRecognitionPermission": "Allow access to speech recognition to send voice commands to the robot."
        }
      ]
    ],
    "android": {
      "package": "com.nordeveloper.biborobotapp",
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "1c2874c6-cd08-47a1-bf81-69bcbfab7698"
      }
    },
    "owner": "nordeveloper"
  }
}
