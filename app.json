{
  "expo": {
    "name": "mobilerobot",
    "slug": "mobilerobot",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "@react-native-voice/voice",
        {
          "microphonePermission": "Разрешите доступ к микрофону для отправки голосовых команд роботу."
        }
      ]
    ]
  }
}
